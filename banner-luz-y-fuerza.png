  <rect x="670" y="490" width="240" height="52" rx="26" fill="url(#star)" opacity="0.9"/>
  <text x="790" y="522" text-anchor="middle" font-family="'Segoe UI', Arial, sans-serif" font-size="16" fill="#ffffff" letter-spacing="2" font-weight="600">VER PRODUCTOS</text>
