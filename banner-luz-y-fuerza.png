  <circle cx="550" cy="520" r="0.8" fill="#fff" opacity="0.25"/>
  <circle cx="1050" cy="450" r="0.9" fill="#fff" opacity="0.35"/>
  <circle cx="1200" cy="380" r="1.1" fill="#fff" opacity="0.28"/>
  <circle cx="1350" cy="500" r="0.7" fill="#fff" opacity="0.3"/>
  <circle cx="1450" cy="350" r="1" fill="#fff" opacity="0.22"/>
  <circle cx="70" cy="250" r="0.8" fill="#fff" opacity="0.3"/>
  <circle cx="700" cy="520" r="0.9" fill="#fff" opacity="0.2"/>
  <circle cx="900" cy="380" r="1.2" fill="#fff" opacity="0.15"/>
  <circle cx="1500" cy="200" r="0.8" fill="#fff" opacity="0.35"/>
  <circle cx="330" cy="290" r="0.6" fill="#c084fc" opacity="0.15"/>
  <circle cx="1180" cy="280" r="0.7" fill="#818cf8" opacity="0.12"/>
  
  <g transform="translate(250, 300)" opacity="0.08">
    <path d="M0,-120 L20,-20 120,0 20,20 0,120 -20,20 -120,0 -20,-20Z" fill="#c084fc"/>
  </g>
  <g transform="translate(1330, 300)" opacity="0.06">
    <path d="M0,-100 L17,-17 100,0 17,17 0,100 -17,17 -100,0 -17,-17Z" fill="#818cf8"/>
  </g>

  <g transform="translate(790, 175)">
    <path d="M0,-55 L10,-10 55,0 10,10 0,55 -10,10 -55,0 -10,-10Z" fill="url(#star)" opacity="0.85"/>
    <path d="M0,-30 L5.5,-5.5 30,0 5.5,5.5 0,30 -5.5,5.5 -30,0 -5.5,-5.5Z" fill="#e8e6f0" opacity="0.4"/>
    <circle cx="0" cy="0" r="4" fill="#fff" opacity="0.9"/>
  </g>
  
  <text x="790" y="305" text-anchor="middle" font-family="Georgia, 'Times New Roman', serif" font-size="64" fill="#e8e6f0" letter-spacing="4" font-weight="400">Encontrá las cartas</text>
  <text x="790" y="380" text-anchor="middle" font-family="Georgia, 'Times New Roman', serif" font-size="64" fill="#c084fc" letter-spacing="4" font-weight="400" font-style="italic">que te estaban esperando</text>
  
  <line x1="560" y1="415" x2="750" y2="415" stroke="#7c3aed" stroke-width="0.5" opacity="0.5"/>
